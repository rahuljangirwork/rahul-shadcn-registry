{
  "name": "rahul-shadcn-registry",
  "type": "module",
  "version": "1.0.0",
  "description": "Custom shadcn/ui component registry by Rahul Jangir",
  "author": "Rahul Jangir <rahuljangir.works@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahuljangirwork/rahul-shadcn-registry.git"
  },
  "homepage": "https://github.com/rahuljangirwork/rahul-shadcn-registry",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && shadcn build && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "registry:build": "shadcn build",
    "prepare": "command -v husky >/dev/null 2>&1 && husky || echo 'Husky not available in CI, skipping...'",
    "lint": "eslint --fix .",
    "format": "prettier --write .",
    "postinstall": "npm run registry:build"
  },
  "lint-staged": {
    "**/*": [
      "prettier --write --ignore-unknown",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.5",
    "@astrojs/react": "^4.4.2",
    "@astrojs/starlight": "^0.36.2",
    "@astrojs/starlight-tailwind": "^4.0.2",
    "@expressive-code/plugin-line-numbers": "^0.41.3",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.17",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "astro": "^5.15.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.553.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "starlight-theme-black": "^0.6.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.9",
    "typescript": "^5.9.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/css": "^0.9.0",
    "@eslint/js": "^9.30.1",
    "@eslint/json": "^0.12.0",
    "@eslint/markdown": "^6.6.0",
    "@typescript-eslint/parser": "^8.36.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "shadcn": "^2.8.0",
    "tw-animate-css": "^1.3.5",
    "typescript-eslint": "^8.36.0",
    "vite": "^5.4.19"
  }
}